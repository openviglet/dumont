#!/usr/bin/env bash
# --------------------------------------------------------------------------
# AppRun - Entry point for the Dumont DEP AppImage.
#
# Usage:
#   ./Dumont-DEP.AppImage                     (starts AEM connector)
#   ./Dumont-DEP.AppImage --connector aem
#   ./Dumont-DEP.AppImage --connector webcrawler
#   ./Dumont-DEP.AppImage --connector db
#   ./Dumont-DEP.AppImage --connector assets
# --------------------------------------------------------------------------
set -euo pipefail

APPDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

CONNECTOR_DIR="$APPDIR/usr/lib/dumont/connector"
JAR="$CONNECTOR_DIR/dumont-connector.jar"
PROPS="$CONNECTOR_DIR/dumont-connector.properties"

CONNECTOR="aem"

# Parse --connector argument
PASSTHROUGH_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --connector)
      CONNECTOR="$2"
      shift 2
      ;;
    *)
      PASSTHROUGH_ARGS+=("$1")
      shift
      ;;
  esac
done

start_connector() {
  local LIBS_DIR="$1"
  local LABEL="$2"
  echo "Starting Dumont Connector ($LABEL)..."
  SPRING_CONFIG=""
  if [ -f "$PROPS" ]; then
    SPRING_CONFIG="--spring.config.additional-location=file:$PROPS"
  fi
  exec java -Xmx512m -Xms512m \
    -Dloader.path="$LIBS_DIR" \
    -jar "$JAR" \
    $SPRING_CONFIG \
    "${PASSTHROUGH_ARGS[@]+"${PASSTHROUGH_ARGS[@]}"}"
}

case "$CONNECTOR" in
  aem)        start_connector "$CONNECTOR_DIR/libs/aem"        "AEM" ;;
  webcrawler) start_connector "$CONNECTOR_DIR/libs/webcrawler" "Web Crawler" ;;
  db)         start_connector "$CONNECTOR_DIR/libs/db"         "Database" ;;
  assets)     start_connector "$CONNECTOR_DIR/libs/assets"     "Assets" ;;
  *)
    echo "Unknown connector: $CONNECTOR"
    echo "Available: aem, webcrawler, db, assets"
    exit 1
    ;;
esac
